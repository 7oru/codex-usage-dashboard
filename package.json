{
  "name": "local-ai-usage-dashboard",
  "version": "0.1.1",
  "description": "Generate a local static dashboard from ccusage-supported AI coding usage data.",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/7oru/local-ai-usage-dashboard.git"
  },
  "homepage": "https://github.com/7oru/local-ai-usage-dashboard#readme",
  "bugs": {
    "url": "https://github.com/7oru/local-ai-usage-dashboard/issues"
  },
  "keywords": [
    "ccusage",
    "ai-coding",
    "usage-dashboard",
    "local-first"
  ],
  "bin": {
    "local-ai-usage-dashboard": "bin/local-ai-usage-dashboard.js"
  },
  "files": [
    "bin/",
    "dist-sample/assets/",
    "public/favicon.svg",
    "sample-data/usage.json",
    "scripts/export-ccusage-json.sh"
  ],
  "scripts": {
    "dev": "vite",
    "build": "bash scripts/build.sh",
    "build:sample": "BUILD_DIR=dist-sample USAGE_DATA_FILE=sample-data/usage.json bash scripts/build.sh",
    "export:data": "bash scripts/export-ccusage-json.sh"
  },
  "devDependencies": {
    "dayjs": "^1.11.13",
    "lucide-react": "^1.16.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "recharts": "^3.8.1",
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.28.0",
    "eslint": "^10.4.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.4",
    "vite": "^5.4.18"
  }
}
